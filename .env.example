# ---------------------------------------------------------------------------
# Wildewood COO Dashboard — environment variables
# Copy this file to ".env" (local) or set these in Vercel > Project > Settings
# > Environment Variables. Never commit your real .env.
# ---------------------------------------------------------------------------

# --- Database (serverless Postgres) ---------------------------------------
# Use Neon, Vercel Postgres, or Supabase. The pooled connection string goes in
# DATABASE_URL; the direct (non-pooled) string goes in DIRECT_URL for migrations.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# --- NextAuth -------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Local dev: http://localhost:3000  |  Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---------------------------------------------------------
# From Google Cloud Console > APIs & Services > Credentials > OAuth client (Web).
# Authorized redirect URI must be: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# --- Access control -------------------------------------------------------
# Comma-separated list of Google account emails allowed to sign in.
# Leave blank to allow any Google account (not recommended for production).
ALLOWED_EMAILS="shaina@wildewoodeducation.com"

# --- AI suggestions -------------------------------------------------------
# The suggestion engine runs fully locally today (no key required). When you are
# ready to upgrade to Claude-powered suggestions, set this key and flip
# AI_PROVIDER to "claude". Until then leave AI_PROVIDER=local.
AI_PROVIDER="local"
# ANTHROPIC_API_KEY="sk-ant-..."
